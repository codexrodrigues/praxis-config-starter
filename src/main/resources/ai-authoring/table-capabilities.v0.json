{
  "version": "0.1.0",
  "kind": "praxis.ai-authoring.component-capability-catalog",
  "componentId": "praxis-table",
  "capabilities": [
    {
      "id": "praxis-table.title.rename@0.1.0",
      "changeKind": "rename_or_relabel",
      "triggerTerms": ["renomear", "renomeie", "label", "rotulo", "titulo", "title"],
      "fieldAliases": [],
      "examples": [
        {
          "prompt": "Renomeie a tabela para Resultados da consulta.",
          "intent": "Alterar o titulo visivel da tabela sem trocar fonte de dados.",
          "configHints": ["inputs.title=Resultados da consulta", "preservar columns e resourcePath"]
        }
      ]
    },
    {
      "id": "praxis-table.column.format.currency-brl@0.1.0",
      "changeKind": "set_column_format",
      "triggerTerms": ["formatar", "formate", "formatacao", "moeda", "reais", "brl"],
      "fieldAliases": [
        { "field": "salarioLiquido", "aliases": ["salario liquido", "salarioLiquido", "liquido"] },
        { "field": "salarioBruto", "aliases": ["salario bruto", "salarioBruto", "bruto"] },
        { "field": "totalDescontos", "aliases": ["total de descontos", "total descontos", "descontos"] }
      ],
      "examples": [
        {
          "prompt": "Formate a coluna numerica selecionada como moeda.",
          "intent": "Aplicar formatacao monetaria a uma coluna numerica.",
          "configHints": ["columns.<schemaField>.format=currency", "columns.<schemaField>.currency=<hostCurrency>"]
        }
      ]
    },
    {
      "id": "praxis-table.column.visibility@0.1.0",
      "changeKind": "set_column_visibility",
      "triggerTerms": ["ocultar", "oculte", "esconder", "esconda", "deixe somente", "deixar somente", "somente", "apenas", "mantenha as colunas", "manter colunas"],
      "fieldAliases": [
        { "field": "salarioLiquido", "aliases": ["salario liquido", "salarioLiquido", "liquido"] },
        { "field": "salarioBruto", "aliases": ["salario bruto", "salarioBruto", "bruto"] },
        { "field": "totalDescontos", "aliases": ["total de descontos", "total descontos", "descontos"] }
      ],
      "examples": [
        {
          "prompt": "Oculte a coluna de identificador.",
          "intent": "Esconder coluna mantendo o dado disponivel no dataset.",
          "configHints": ["columns.<schemaField>.visible=false", "nao remover resourcePath nem schema"]
        }
      ]
    },
    {
      "id": "praxis-table.column.order@0.1.0",
      "changeKind": "set_column_order",
      "triggerTerms": ["mover", "mova", "reordenar", "reordene", "primeira", "inicio"],
      "fieldAliases": [
        { "field": "salarioLiquido", "aliases": ["salario liquido", "salarioLiquido", "liquido"] },
        { "field": "salarioBruto", "aliases": ["salario bruto", "salarioBruto", "bruto"] },
        { "field": "totalDescontos", "aliases": ["total de descontos", "total descontos", "descontos"] }
      ],
      "examples": [
        {
          "prompt": "Mova a coluna selecionada para a primeira posicao.",
          "intent": "Reordenar colunas sem alterar contrato de dados.",
          "configHints": ["columns order startsWith <schemaField>", "preservar definicoes das demais colunas"]
        }
      ]
    }
  ]
