{
  "version": "0.1.0",
  "kind": "praxis.ai-authoring.component-capability-catalog",
  "componentId": "praxis-dynamic-form",
  "capabilities": [
    {
      "id": "praxis-dynamic-form.field.add-local@0.1.0",
      "changeKind": "add_field",
      "triggerTerms": ["adicionar", "adicione", "incluir", "inclua", "acrescentar", "acrescente"],
      "fieldAliases": [],
      "examples": [
        {
          "prompt": "Adicione um campo local de anotacao.",
          "intent": "Criar campo auxiliar no formulario sem enviar ao backend.",
          "configHints": ["field.source=local", "field.transient=true", "submitPolicy.includeInPayload=false"]
        }
      ]
    },
    {
      "id": "praxis-dynamic-form.field.relabel@0.1.0",
      "changeKind": "rename_or_relabel",
      "triggerTerms": ["renomear", "renomeie", "label", "rotulo", "titulo"],
      "fieldAliases": [],
      "examples": [
        {
          "prompt": "Renomeie o campo selecionado para um rotulo mais claro.",
          "intent": "Alterar apenas o rotulo visivel preservando o campo de dados.",
          "configHints": ["field.name preservado", "field.label=<novoRotulo>"]
        }
      ]
    },
    {
      "id": "praxis-dynamic-form.field.remove-local@0.1.0",
      "changeKind": "remove_field",
      "triggerTerms": ["remover", "remova", "remove", "excluir", "exclua", "apagar", "apague", "retirar", "retire", "campo", "campos"],
      "fieldAliases": [],
      "examples": [
        {
          "prompt": "Remova o campo local selecionado.",
          "intent": "Remover somente campos criados localmente pelo autor.",
          "configHints": ["permitir remocao quando field.source=local", "bloquear remocao de campo vindo do schema remoto"]
        }
      ]
    }
  ]
}
